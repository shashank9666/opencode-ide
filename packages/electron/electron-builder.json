{
  "appId": "com.opencode.app",
  "productName": "OpenCode",
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "files": [
    "dist/**/*"
  ],
  "extraResources": [
    {
      "from": "../../.opencode",
      "to": ".opencode",
      "filter": ["**/*"]
    },
    {
      "from": "../app/dist",
      "to": "app-dist",
      "filter": ["**/*"]
    },
    {
      "from": "../opencode/dist",
      "to": "backend-binaries",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
